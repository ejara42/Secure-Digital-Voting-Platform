{
  "name": "secure-digital-voting-platform-backend",
  "version": "1.0.0",
  "description": "Backend for the Voter React app (Express + MongoDB)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:localstack": "docker-compose -f docker-compose.localstack.yml up -d && node scripts/localstack-test.js && docker-compose -f docker-compose.localstack.yml down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.427.0",
    "@aws-sdk/lib-storage": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.427.0",
    "@google/generative-ai": "^0.24.1",
    "africastalking": "^0.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.11",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.10.0",
    "resend": "^6.9.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.5.0",
    "jest": "^29.0.0",
    "mongodb-memory-server": "^8.12.0",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup/integrationSetup.js"
    ],
    "testTimeout": 30000,
    "transformIgnorePatterns": [
      "node_modules/(?!@aws-sdk|uuid)"
    ]
  }
}
